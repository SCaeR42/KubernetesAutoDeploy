#!/usr/bin/env bash
# Общие переменные для скриптов в этой папке. Обязательно заполните
# VPS_HOST перед первым запуском (IP или доменное имя вашего сервера).
export VPS_HOST=""                 # например: 203.0.113.10 или my-vps.example.com
export VPS_USER="root"             # пользователь для SSH (у большинства VPS-провайдеров - root)
export VPS_SSH_KEY=""              # опционально: путь к приватному ключу, напр. ~/.ssh/id_rsa
                                    # если пусто - используется ssh-agent/дефолтный ключ

export VPS_KUBECTL_CONTEXT="vps-php-helloworld"

export IMAGE_NAME="php-helloworld"
export IMAGE_TAG="latest"

# Собранные ssh/scp с учётом опционального ключа
ssh_opts() {
    local opts=(-o StrictHostKeyChecking=accept-new)
    if [[ -n "$VPS_SSH_KEY" ]]; then
        opts+=(-i "$VPS_SSH_KEY")
    fi
    echo "${opts[@]}"
}
